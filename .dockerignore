# Python-generated files
**/__pycache__
**/*.py[oc]
**/build
**/dist
**/wheels
**/*.egg-info

# Virtual environments
.venv
**/.venv

# macOS
.DS_Store
**/.DS_Store

# IDEs
.vscode
.idea

# Local files
*.log
**/*.log

# Jupyter notebooks / checkpoints
**/*.ipynb_checkpoints
**/.ipynb_checkpoints
**/**/.ipynb_checkpoints
**/*checkpoint.ipynb

# Test/quality caches
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
htmlcov
coverage.xml

# Git and GitHub metadata are not needed in the Docker context.
.git
.github

# Local data should be mounted, not baked into the image.
data
